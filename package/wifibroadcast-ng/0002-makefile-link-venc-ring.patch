Add venc_ring.o to wfb_tx so the SHM input mode (0001-shm-input-tx.patch)
links cleanly. The existing src/%.o pattern rule already covers building
venc_ring.o from venc_ring.c, and -lrt is already in _LDFLAGS via the
wfb-ng Makefile's libsodium link path.

--- a/Makefile
+++ b/Makefile
@@ -50,7 +50,7 @@ src/%.o: src/%.cpp src/*.hpp src/*.h
 wfb_rx: src/rx.o src/radiotap.o src/zfex.o src/wifibroadcast.o
 	$(CXX) -o $@ $^ $(_LDFLAGS) -lpcap

-wfb_tx: src/tx.o src/zfex.o src/wifibroadcast.o
+wfb_tx: src/tx.o src/zfex.o src/wifibroadcast.o src/venc_ring.o
 	$(CXX) -o $@ $^ $(_LDFLAGS)

 fec_test: src/fec_test.cpp src/zfex.o
